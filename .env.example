# Base URL
NEXT_PUBLIC_BASE_URL=https://www.bayviewhub.me

# Supabase (required for form submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Feasibility + SSD server APIs use getSupabaseServer(): URL = SUPABASE_URL || NEXT_PUBLIC_SUPABASE_URL; key = SUPABASE_SECRET_KEY || SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Server-only — same value as service role; SSD campaign API also accepts SUPABASE_SERVICE_ROLE_KEY name
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# Email Service (optional - for email notifications)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Bayview Hub <hello@bayviewhub.me>

# SSD campaign: digests + instant alerts (Resend). Feasibility notify list (comma-separated).
SSD_CAMPAIGN_OWNER_EMAIL=ileonzh@gmail.com
FEASIBILITY_NOTIFY_TO=leonzh@bayviewestate.com.au,ileonzh@gmail.com

# Vercel Cron (set in Vercel dashboard) — secures /api/cron/ssd-*-digest
CRON_SECRET=generate_a_long_random_string

# Temporary: set to 1 in Vercel to expose supabase_code/supabase_message on insert_failed (remove after debugging)
# SSD_INSERT_DEBUG=1

# Notification Emails (optional)
PARTNERS_NOTIFY_EMAIL=partners@bayviewhub.me
EOI_GALLERY_NOTIFY_EMAIL=gallery@bayviewhub.me
EOI_EDIBLE_GARDENS_NOTIFY_EMAIL=gardens@bayviewhub.me

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=bayviewhub.me

# Social Media (optional)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
