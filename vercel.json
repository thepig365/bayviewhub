{
  "crons": [
    {
      "path": "/api/cron/ssd-daily-digest",
      "schedule": "30 21 * * *"
    },
    {
      "path": "/api/cron/ssd-weekly-digest",
      "schedule": "0 7 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/pigandwhistle",
      "destination": "https://thepigandwhistle.com.au"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}

